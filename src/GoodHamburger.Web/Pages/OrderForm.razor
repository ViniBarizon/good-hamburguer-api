@page "/orders/new"
@page "/orders/edit/{Id:guid}"
@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@inject ApiService Api
@inject NavigationManager Nav

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <span style="font-size:2.5rem">@(_isEdit ? "✏️" : "➕")</span>
        <div>
            <h2>@(_isEdit ? "Edit Order" : "New Order")</h2>
            <p>@(_isEdit ? "Update the items in this order." : "Select one item per type to build your order.")</p>
        </div>
    </div>
</div>

@if (_menu is null)
{
    <div class="loading-state">
        <div class="fs-1">⏳</div>
        <p>Loading menu...</p>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <h6 class="fw-bold mb-3">🍔 Sandwiches <span class="text-muted fw-normal">(pick one)</span></h6>
            @foreach (var item in _menu.Where(i => i.Type == "Sandwich"))
            {
                <div class="item-checkbox-card @(_selected.Contains(item.Id) ? "selected" : "")"
                     @onclick="() => ToggleItem(item.Id, item.Type)">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <input type="checkbox" class="form-check-input me-2"
                                   checked="@_selected.Contains(item.Id)"
                                   @onclick:stopPropagation="true"
                                   @onchange="e => ToggleItem(item.Id, item.Type)" />
                            <span class="menu-item-name">@item.Name</span>
                        </div>
                        <span class="item-price">R$ @item.Price.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <h6 class="fw-bold mb-3">🍟 Sides <span class="text-muted fw-normal">(pick one)</span></h6>
            @foreach (var item in _menu.Where(i => i.Type == "Side"))
            {
                <div class="item-checkbox-card @(_selected.Contains(item.Id) ? "selected" : "")"
                     @onclick="() => ToggleItem(item.Id, item.Type)">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <input type="checkbox" class="form-check-input me-2"
                                   checked="@_selected.Contains(item.Id)"
                                   @onclick:stopPropagation="true"
                                   @onchange="e => ToggleItem(item.Id, item.Type)" />
                            <span class="menu-item-name">@item.Name</span>
                        </div>
                        <span class="item-price">R$ @item.Price.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <h6 class="fw-bold mb-3">🥤 Drinks <span class="text-muted fw-normal">(pick one)</span></h6>
            @foreach (var item in _menu.Where(i => i.Type == "Drink"))
            {
                <div class="item-checkbox-card @(_selected.Contains(item.Id) ? "selected" : "")"
                     @onclick="() => ToggleItem(item.Id, item.Type)">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <input type="checkbox" class="form-check-input me-2"
                                   checked="@_selected.Contains(item.Id)"
                                   @onclick:stopPropagation="true"
                                   @onchange="e => ToggleItem(item.Id, item.Type)" />
                            <span class="menu-item-name">@item.Name</span>
                        </div>
                        <span class="item-price">R$ @item.Price.ToString("F2")</span>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (_selected.Any())
    {
        <div class="card mt-4 p-3" style="border-left: 4px solid var(--burger-primary)">
            <strong>🧾 @_selected.Count item(s) selected</strong>
            <span class="text-muted ms-2" style="font-size:0.85rem">
                @string.Join(", ", _menu.Where(i => _selected.Contains(i.Id)).Select(i => i.Name))
            </span>
        </div>
    }

    @if (_errorMessage is not null)
    {
        <div class="alert alert-danger mt-3 rounded-3">
            ⚠️ @_errorMessage
        </div>
    }

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-burger" @onclick="Submit">
            <i class="bi bi-check-lg me-2"></i>@(_isEdit ? "Update Order" : "Place Order")
        </button>
        <button class="btn btn-outline-secondary rounded-3" @onclick="Cancel">
            Cancel
        </button>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private List<MenuItemModel>? _menu;
    private HashSet<int> _selected = new();
    private string? _errorMessage;
    private bool _isEdit => Id.HasValue;

    protected override async Task OnInitializedAsync()
    {
        _menu = await Api.GetMenuAsync();

        if (_isEdit)
        {
            var order = await Api.GetOrderAsync(Id!.Value);
            if (order is not null)
                _selected = order.Items.Select(i => i.Id).ToHashSet();
        }
    }

    private void ToggleItem(int id, string type)
    {
        // Se já selecionado, desmarca
        if (_selected.Contains(id))
        {
            _selected.Remove(id);
            _errorMessage = null;
            return;
        }

        // Remove qualquer outro item do mesmo tipo antes de adicionar
        var sameType = _menu!.Where(i => i.Type == type && _selected.Contains(i.Id)).ToList();
        foreach (var item in sameType)
            _selected.Remove(item.Id);

        _selected.Add(id);
        _errorMessage = null;
    }

    private async Task Submit()
    {
        if (!_selected.Any())
        {
            _errorMessage = "Please select at least one item.";
            return;
        }

        var model = new CreateOrderModel { MenuItemIds = _selected.ToList() };

        var result = _isEdit
            ? await Api.UpdateOrderAsync(Id!.Value, model)
            : await Api.CreateOrderAsync(model);

        if (result is not null)
            Nav.NavigateTo("/orders");
        else
            _errorMessage = "Failed to save order. Please try again.";
    }

    private void Cancel() => Nav.NavigateTo("/orders");
}