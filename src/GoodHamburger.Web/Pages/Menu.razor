@page "/menu"
@using GoodHamburger.Web.Models
@using GoodHamburger.Web.Services
@inject ApiService Api

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <span style="font-size:2.5rem">📋</span>
        <div>
            <h2>Our Menu</h2>
            <p>Fresh ingredients, great prices.</p>
        </div>
    </div>
</div>

@if (_items is null)
{
    <div class="loading-state">
        <div class="fs-1">⏳</div>
        <p>Loading menu...</p>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card menu-card h-100">
                <div class="card-header">🍔 Sandwiches</div>
                <div class="card-body">
                    @foreach (var item in _items.Where(i => i.Type == "Sandwich"))
                    {
                        <div class="menu-item-row">
                            <span class="menu-item-name">@item.Name</span>
                            <span class="menu-item-price">R$ @item.Price.ToString("F2")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card menu-card h-100">
                <div class="card-header">🍟 Sides</div>
                <div class="card-body">
                    @foreach (var item in _items.Where(i => i.Type == "Side"))
                    {
                        <div class="menu-item-row">
                            <span class="menu-item-name">@item.Name</span>
                            <span class="menu-item-price">R$ @item.Price.ToString("F2")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card menu-card h-100">
                <div class="card-header">🥤 Drinks</div>
                <div class="card-body">
                    @foreach (var item in _items.Where(i => i.Type == "Drink"))
                    {
                        <div class="menu-item-row">
                            <span class="menu-item-name">@item.Name</span>
                            <span class="menu-item-price">R$ @item.Price.ToString("F2")</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<MenuItemModel>? _items;

    protected override async Task OnInitializedAsync() =>
        _items = await Api.GetMenuAsync();
}